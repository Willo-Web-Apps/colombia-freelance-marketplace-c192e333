---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Your New Business", description = "Build a social marketplace for freelance workers in the Colombia. Medellin area and give them uniform scoring system so they can be measured on the same playing field. I also create a Messaging section so they can send contracts back-and-forth, and with an integrated payment system so they can send payments back and forth for jobs and gigs, and add an event section as well, and make sure the jobs can be attached to those events" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Your New Business",
      "description": "Build a social marketplace for freelance workers in the Colombia. Medellin area and give them uniform scoring system so they can be measured on the same playing field. I also create a Messaging section so they can send contracts back-and-forth, and with an integrated payment system so they can send payments back and forth for jobs and gigs, and add an event section as well, and make sure the jobs can be attached to those events",
      "url": "https://colombia-freelance-marketplace.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
