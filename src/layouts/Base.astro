---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Parcelab — Where Medellín's Talent Gets to Work", description = "Parcelab is the first social marketplace for Medellín freelancers. Fair scoring, secure contracts, event gigs, and integrated payments — all in one place." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Parcelab",
      "description": "Parcelab is the first social marketplace for Medellín freelancers. Fair scoring, secure contracts, event gigs, and integrated payments — all in one place.",
      "url": "https://colombia-freelance-marketplace.onrender.com",
      "foundingLocation": "Medellín, Colombia"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-950 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
