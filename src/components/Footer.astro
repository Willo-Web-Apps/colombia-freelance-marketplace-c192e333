---
const year = new Date().getFullYear();
---
<footer class="border-t border-surface-300/50 bg-surface-50 py-14">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand column -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <span class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center text-white font-display text-sm leading-none select-none">P</span>
          <span class="font-display text-lg text-surface-950 tracking-tight">Parcelab</span>
        </a>
        <p class="text-sm text-surface-800 leading-relaxed max-w-xs">
          El marketplace de talento freelance hecho para Medellín. Justo, local, y construido por la comunidad.
        </p>
        <!-- Tagline pill -->
        <div class="mt-5 inline-block bg-brand-500/15 border border-brand-500/25 px-4 py-2 rounded-full">
          <p class="text-xs font-semibold text-brand-400 tracking-wide">Where Medellín's talent gets to work</p>
        </div>
      </div>

      <!-- Platform links -->
      <div>
        <p class="text-xs font-semibold text-surface-950 uppercase tracking-widest mb-4">Plataforma</p>
        <ul class="space-y-3">
          <li><a href="#how-it-works" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Cómo funciona</a></li>
          <li><a href="#features" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Funciones</a></li>
          <li><a href="#join" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Hub de Eventos</a></li>
          <li><a href="#join" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Parce Score</a></li>
        </ul>
      </div>

      <!-- Company links -->
      <div>
        <p class="text-xs font-semibold text-surface-950 uppercase tracking-widest mb-4">Compañía</p>
        <ul class="space-y-3">
          <li><a href="#" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Sobre Parcelab</a></li>
          <li><a href="#" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Blog</a></li>
          <li><a href="#" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Términos</a></li>
          <li><a href="#" class="text-sm text-surface-800 hover:text-surface-950 transition-colors">Privacidad</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-surface-300/50 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-xs text-surface-800">&copy; {year} Parcelab SAS. Hecho con orgullo en Medellín, Colombia 🇨🇴</p>
      <p class="text-xs text-surface-800">
        <a href="mailto:hola@parcelab.co" class="hover:text-surface-950 transition-colors">hola@parcelab.co</a>
      </p>
    </div>

  </div>
</footer>
