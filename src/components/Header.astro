---
<header class="sticky top-0 z-50 border-b border-surface-300/50 bg-surface-50/85 backdrop-blur-xl">
  <nav class="max-w-6xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
    <!-- Logotype -->
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- P monogram badge -->
      <span class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center text-white font-display text-sm leading-none select-none">P</span>
      <span class="font-display text-lg text-surface-950 tracking-tight">Parcelab</span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#how-it-works" class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors">Cómo funciona</a>
      <a href="#features" class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors">Funciones</a>
      <a href="#join" class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors">Para Empresas</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#join" class="hidden sm:inline-block text-sm font-medium text-surface-900 hover:text-surface-950 transition-colors">
        Iniciar sesión
      </a>
      <a
        href="#join"
        class="inline-flex items-center gap-2 text-sm font-semibold bg-brand-500 hover:bg-brand-400 text-white px-4 py-2.5 rounded-xl transition-all duration-200 hover:shadow-md hover:shadow-brand-500/25"
      >
        Únete gratis
        <svg class="w-3.5 h-3.5" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2.5 7h9M8 3l4 4-4 4"/>
        </svg>
      </a>
    </div>
  </nav>
</header>
